{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "ADW Assistent v3",
  "version": "3.0.0",
  "identifier": "com.adw.assistent.v3",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ADW Assistent v3",
        "width": 920,
        "height": 680,
        "minWidth": 800,
        "minHeight": 580,
        "center": true,
        "decorations": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/adw.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Portuguese"]
      }
    }
  }
}
